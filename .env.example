# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Active environment: dev | staging | prod
# Switch at runtime: ENV=staging robot -d results api/tests/
ENV=dev

# URLs per environment — fill in the ones you use
DEV_URL=https://restful-booker.herokuapp.com/
STAGING_URL=
PROD_URL=

# Auth strategy: basic | oauth | api_key | none
AUTH_TYPE=basic

# --- Basic Auth ---
API_USERNAME=admin
API_PASSWORD=password123

# --- OAuth (Client Credentials) ---
# Required when AUTH_TYPE=oauth
TOKEN_URL=
CLIENT_ID=
CLIENT_SECRET=

# --- API Key ---
# Required when AUTH_TYPE=api_key
API_KEY=
API_KEY_HEADER=x-api-key
